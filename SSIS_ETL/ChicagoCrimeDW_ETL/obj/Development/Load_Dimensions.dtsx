                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    UPPER(ISNULL(NULLIF(TRIM(Block),''),'UNKNOWN'))        AS block,
    CAST(ISNULL(NULLIF(TRIM(Beat),''),'0') AS INT)         AS beat,
    CAST(ISNULL(NULLIF(TRIM(District),''),'0') AS INT)     AS district,
    CAST(ISNULL(NULLIF(TRIM(Ward),''),'0') AS INT)         AS ward,
    UPPER(ISNULL(NULLIF(TRIM(LocationDesc),''),'UNKNOWN')) AS location_desc,
    CAST(ISNULL(NULLIF(TRIM(Latitude),''),'0') AS FLOAT)   AS latitude,
    CAST(ISNULL(NULLIF(TRIM(Longitude),''),'0') AS FLOAT)  AS longitude
FROM ChicagoCrime_Staging.dbo.stg_crimes
WHERE Block IS NOT NULL
  AND Beat IS NOT NULL
  AND Beat &lt;&gt; ''</property>
