              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[dbo].[vw_DimCommunityArea]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    community_area_number,
    community_area_name,
    per_capita_income,
    poverty_rate,
    unemployment_rate,
    hardship_index,
    CAST(hardship_band AS NVARCHAR(20)) AS hardship_band,
    scd_start_date,
    scd_end_date,
    is_current
FROM (
    SELECT
        CAST(ISNULL(NULLIF(TRIM(CommunityAreaNumber),''),'0')
             AS INT)                        AS community_area_number,
        CAST(UPPER(TRIM(CommunityAreaName))
             AS NVARCHAR(100))              AS community_area_name,
        CAST(ISNULL(NULLIF(TRIM(PerCapitaIncome),''),'0')
             AS FLOAT)                      AS per_capita_income,
        CAST(ISNULL(NULLIF(TRIM(PovertyRate),''),'0')
             AS FLOAT)                      AS poverty_rate,
        CAST(ISNULL(NULLIF(TRIM(UnemploymentRate),''),'0')
             AS FLOAT)                      AS unemployment_rate,
        CAST(ISNULL(NULLIF(TRIM(HardshipIndex),''),'0')
             AS FLOAT)                      AS hardship_index,
        CASE
            WHEN CAST(ISNULL(NULLIF(TRIM(HardshipIndex),''),'0')
                 AS FLOAT) &lt;= 25 THEN N'Low'
            WHEN CAST(ISNULL(NULLIF(TRIM(HardshipIndex),''),'0')
                 AS FLOAT) &lt;= 50 THEN N'Medium'
            WHEN CAST(ISNULL(NULLIF(TRIM(HardshipIndex),''),'0')
                 AS FLOAT) &lt;= 75 THEN N'High'
            ELSE N'Very High'
        END                                 AS hardship_band,
        CAST(GETDATE() AS DATE)             AS scd_start_date,
        CAST(NULL AS DATE)                  AS scd_end_date,
        CAST(1 AS BIT)                      AS is_current
    FROM ChicagoCrime_Staging.dbo.stg_census
    WHERE CommunityAreaNumber IS NOT NULL
      AND CommunityAreaNumber &lt;&gt; ''
) AS src</property>
